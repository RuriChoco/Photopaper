<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="Adw" version="1.0"/>
  <object class="GtkSizeGroup" id="spin_size_group">
    <property name="mode">horizontal</property>
    <widgets>
      <widget name="tolerance_spin"/>
      <widget name="brightness_spin"/>
      <widget name="contrast_spin"/>
      <widget name="sharpen_spin"/>
    </widgets>
  </object>
  <template class="PhotopaperWindow" parent="AdwApplicationWindow">
    <property name="title" translatable="yes">Photopaper</property>
    <property name="default-width">1000</property>
    <property name="default-height">750</property>
    <property name="content">
      <object class="AdwOverlaySplitView" id="split_view">
        <property name="sidebar">
          <object class="AdwToolbarView">
            <child type="top">
              <object class="AdwHeaderBar"/>
            </child>
            <property name="content">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="width-request">380</property>
                <child>
                  <object class="AdwPreferencesPage">
                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Settings</property>
                        
                        <child>
                          <object class="AdwActionRow" id="open_row">
                            <property name="title" translatable="yes">Open Photo</property>
                            <property name="activatable">True</property>
                            <property name="action-name">win.open</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">document-open-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwComboRow" id="paper_size_row">
                            <property name="title" translatable="yes">Paper Size</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">document-page-setup-symbolic</property>
                              </object>
                            </child>
                            <property name="model">
                              <object class="GtkStringList">
                                <items>
                                  <item translatable="yes">4R (4x6")</item>
                                  <item translatable="yes">5R (5x7")</item>
                                  <item translatable="yes">A4</item>
                                </items>
                              </object>
                            </property>
                          </object>
                        </child>
                        
                        <child>
                          <object class="AdwComboRow" id="id_size_row">
                            <property name="title" translatable="yes">ID Size / Layout</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">view-grid-symbolic</property>
                              </object>
                            </child>
                            <property name="model">
                              <object class="GtkStringList">
                                <items>
                                  <item translatable="yes">1x1 Inch</item>
                                  <item translatable="yes">2x2 Inch</item>
                                  <item translatable="yes">Passport (35x45mm)</item>
                                  <item translatable="yes">Combo Package</item>
                                </items>
                              </object>
                            </property>
                          </object>
                        </child>
                        
                        <child>
                          <object class="AdwActionRow" id="export_row">
                            <property name="title" translatable="yes">Export Layout...</property>
                            <property name="activatable">True</property>
                            <property name="sensitive">False</property>
                            <property name="action-name">win.export</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">document-save-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        
                        <child>
                          <object class="AdwActionRow" id="print_row">
                            <property name="title" translatable="yes">Print Layout...</property>
                            <property name="activatable">True</property>
                            <property name="sensitive">False</property>
                            <property name="action-name">win.print</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">printer-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        
                      </object>
                    </child>
                    <child>
                      <object class="AdwPreferencesGroup" id="photo_editing_group">
                        <property name="title" translatable="yes">Photo Editing</property>
                        <property name="sensitive">False</property>
                        
                        <child>
                          <object class="AdwActionRow" id="crop_row">
                            <property name="title" translatable="yes">Crop Photo</property>
                            <property name="subtitle" translatable="yes">Rule of Thirds alignment</property>
                            <property name="activatable">True</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">edit-cut-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwSwitchRow" id="bg_remove_switch">
                            <property name="title" translatable="yes">Remove Background</property>
                            <property name="subtitle" translatable="yes">Auto-fill with white</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">user-invisible-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesRow" id="tolerance_row">
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">color-select-symbolic</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Fill Tolerance</property>
                                        <property name="xalign">0</property>
                                        <property name="hexpand">True</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkScale" id="tolerance_scale">
                                        <property name="hexpand">True</property>
                                        <property name="valign">center</property>
                                        <property name="draw-value">False</property>
                                        <property name="adjustment">
                                          <object class="GtkAdjustment" id="tolerance_adj">
                                            <property name="lower">0.0</property>
                                            <property name="upper">0.5</property>
                                            <property name="value">0.1</property>
                                            <property name="step-increment">0.01</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSpinButton" id="tolerance_spin">
                                        <property name="valign">center</property>
                                        <property name="adjustment">tolerance_adj</property>
                                        <property name="numeric">True</property>
                                        <property name="digits">2</property>
                                        <property name="width-request">80</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">display-brightness-symbolic</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Brightness</property>
                                        <property name="xalign">0</property>
                                        <property name="hexpand">True</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkScale" id="brightness_scale">
                                        <property name="hexpand">True</property>
                                        <property name="valign">center</property>
                                        <property name="draw-value">False</property>
                                        <property name="adjustment">
                                          <object class="GtkAdjustment" id="brightness_adj">
                                            <property name="lower">-100</property>
                                            <property name="upper">100</property>
                                            <property name="value">0</property>
                                            <property name="step-increment">1</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSpinButton" id="brightness_spin">
                                        <property name="valign">center</property>
                                        <property name="adjustment">brightness_adj</property>
                                        <property name="numeric">True</property>
                                        <property name="width-request">80</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">weather-clear-night-symbolic</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Contrast</property>
                                        <property name="xalign">0</property>
                                        <property name="hexpand">True</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkScale" id="contrast_scale">
                                        <property name="hexpand">True</property>
                                        <property name="valign">center</property>
                                        <property name="draw-value">False</property>
                                        <property name="adjustment">
                                          <object class="GtkAdjustment" id="contrast_adj">
                                            <property name="lower">-50</property>
                                            <property name="upper">50</property>
                                            <property name="value">0</property>
                                            <property name="step-increment">1</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSpinButton" id="contrast_spin">
                                        <property name="valign">center</property>
                                        <property name="adjustment">contrast_adj</property>
                                        <property name="numeric">True</property>
                                        <property name="width-request">80</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">view-reveal-symbolic</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Sharpen</property>
                                        <property name="xalign">0</property>
                                        <property name="hexpand">True</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkScale" id="sharpen_scale">
                                        <property name="hexpand">True</property>
                                        <property name="valign">center</property>
                                        <property name="draw-value">False</property>
                                        <property name="adjustment">
                                          <object class="GtkAdjustment" id="sharpen_adj">
                                            <property name="lower">0.0</property>
                                            <property name="upper">5.0</property>
                                            <property name="value">0.0</property>
                                            <property name="step-increment">0.1</property>
                                            <property name="page-increment">1.0</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSpinButton" id="sharpen_spin">
                                        <property name="valign">center</property>
                                        <property name="adjustment">sharpen_adj</property>
                                        <property name="numeric">True</property>
                                        <property name="digits">1</property>
                                        <property name="width-request">80</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwActionRow" id="revert_row">
                            <property name="title" translatable="yes">Revert to Original</property>
                            <property name="activatable">True</property>
                            <property name="action-name">win.revert</property>
                            <child type="prefix">
                              <object class="GtkImage">
                                <property name="icon-name">view-refresh-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>

                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </property>
        <property name="content">
          <object class="AdwToolbarView">
                <child type="top">
                  <object class="AdwHeaderBar">
                    <property name="title-widget">
                      <object class="AdwWindowTitle" id="main_title">
                        <property name="title" translatable="yes">No Photo Selected</property>
                      </object>
                    </property>
                    <child type="end">
                      <object class="GtkMenuButton">
                        <property name="primary">True</property>
                        <property name="icon-name">open-menu-symbolic</property>
                        <property name="tooltip-text" translatable="yes">Main Menu</property>
                        <property name="menu-model">primary_menu</property>
                      </object>
                    </child>
                  </object>
                </child>
                <property name="content">
                  <object class="GtkStack" id="content_stack">
                    <property name="transition-type">crossfade</property>
                    
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">empty</property>
                        <property name="child">
                          <object class="AdwStatusPage">
                            <property name="icon-name">avatar-default-symbolic</property>
                            <property name="title" translatable="yes">No Photo Selected</property>
                            <property name="description" translatable="yes">Open a portrait photo to begin editing and creating print layouts.</property>
                            <child>
                              <object class="GtkButton" id="status_open_btn">
                                <property name="label" translatable="yes">Open Photo</property>
                                <property name="halign">center</property>
                                <property name="action-name">win.open</property>
                                <style>
                                  <class name="pill"/>
                                  <class name="suggested-action"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">editor</property>
                        <property name="child">
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <child>
                              <object class="GtkScrolledWindow" id="scrolled_window">
                                <property name="hexpand">True</property>
                                <property name="vexpand">True</property>
                                <child>
                                  <object class="GtkPicture" id="preview_picture">
                                    <property name="can-shrink">True</property>
                                    <property name="content-fit">contain</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <property name="margin-top">24</property>
                                    <property name="margin-bottom">24</property>
                                    <property name="margin-start">24</property>
                                    <property name="margin-end">24</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkScale" id="zoom_scale">
                                <property name="orientation">vertical</property>
                                <property name="inverted">True</property>
                                <property name="valign">center</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">24</property>
                                <property name="margin-end">16</property>
                                <property name="margin-start">8</property>
                                <property name="draw-value">False</property>
                                <property name="height-request">250</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">1.0</property>
                                    <property name="upper">10.0</property>
                                    <property name="value">1.0</property>
                                    <property name="step-increment">0.1</property>
                                    <property name="page-increment">1.0</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
        </property>
      </object>
    </property>
  </template>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Preferences</attribute>
        <attribute name="action">app.preferences</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Keyboard Shortcuts</attribute>
        <attribute name="action">app.shortcuts</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_About Photopaper</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
</interface>
